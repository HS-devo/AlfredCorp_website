rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /marketing_opt_ins/{docId} {
      // Allow create and update (setDoc might act as an update if the user already exists)
      allow create, update: if request.resource.data.keys().hasAll(['email', 'name', 'optedInAt']);
    }
  }
}

